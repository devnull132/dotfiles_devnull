[
  {
    "exec": "swaylock --screenshots --key-hl-color FF8941 --indicator --indicator-radius 150 --clock --fade-in 0.2 --effect-vignette 0.7:0.7 --ring-color FFC041 --effect-blur 10x6",
    "icon": "/usr/share/nwg-bar/images/system-lock-screen.svg"
  },
  {
    "exec": "niri msg action quit",
    "icon": "/usr/share/nwg-bar/images/system-log-out.svg"
  },
  {
    "exec": "systemctl reboot",
    "icon": "/usr/share/nwg-bar/images/system-reboot.svg"
  },
  {
    "exec": "systemctl -i poweroff",
    "icon": "/usr/share/nwg-bar/images/system-shutdown.svg"
  }
 ]
