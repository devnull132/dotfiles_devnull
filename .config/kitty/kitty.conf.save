# ===== Шрифты и текст =====
font_family JetBrainsMono Nerd Font Mono
bold_font FiraCode Nerd Font Bold
italic_font VictorMono Nerd Font Italic
bold_italic_font ComicShannsMono Nerd Font Bold Italic
font_size 11.5
adjust_line_height 100%
adjust_column_width 100%
disable_ligatures never
font_features FiraCodeNFM-Reg +ss01 +ss02 +ss03 +ss04 +ss05 +ss06 +zero +onum
box_drawing_scale 0.001, 1, 1.5, 2

# ===== Визуальные эффекты =====
background_image_layout scaled
background_tint 0.85
background_opacity 0.6
dynamic_background_opacity yes
background_blur 100
background_image_animation yes
background_image_frame_duration 0.05
background_image_stop 60

# ===== Курсор =====
cursor_shape beam
cursor_beam_thickness 1.8
cursor_blink_interval 0.5
cursor_stop_blinking_after 15.0

# ===== Вкладки =====
tab_bar_style custom
tab_bar_style powerline
active_tab_foreground   #ff6e88
inactive_tab_foreground #a9b1d6
active_tab_font_style bold-italic
inactive_tab_font_style normal
tab_bar_margin_width 5.0
tab_bar_margin_height 5.0 3.0
tab_bar_align left
tab_title_template " {fmt.fg._5e81ac}{fmt.bg.default}{fmt.fg._d8dee9}{fmt.bg._5e81ac} {title.split()[0]} {fmt.fg._5e81ac}{fmt.bg.default} "
active_tab_title_template " {fmt.fg._a3be8c}{fmt.bg.default}{fmt.fg._2e3440}{fmt.bg._a3be8c}  {title.split()[0]} {fmt.fg._a3be8c}{fmt.bg.default} "

# ===== Цветовая схема Catppuccin Mocha =====
foreground #cdd6f4
background #1e1e2e
selection_foreground #1e1e2e
selection_background #f5e0dc
url_color #89b4fa
color0 #45475a
#cdd6f4color1 #cba6f7
color2 #a6e3a1
color3 #f9e2af
color4 #89b4fa
color5 #f5c2e7
color6 #94e2d5
color7 #bac2de
color8 #585b70
color9 #cba6f7
color10 #a6e3a1
color11 #f9e2af
color12 #89b4fa
color13 #f5c2e7
color14 #94e2d5
color15 #a6adc8
# ===== Горячие клавиши =====
map ctrl+shift+up move_window up
map ctrl+shift+down move_window down
map ctrl+shift+left move_window left
map ctrl+shift+right move_window right
map ctrl+shift+u>1 set_background_opacity +0.1
map ctrl+shift+u>2 set_background_opacity -0.1
map ctrl+shift+u>0 set_background_opacity 1.0
map ctrl+shift+p kitten hints --type path --program -
map ctrl+shift+h show_scrollback
map ctrl+shift+g kitten themes
map ctrl+shift+h launch --location=hsplit
# ===== Декор и границы =====
shell_integration enabled
draw_minimal_borders yes
window_border_width 1.5
active_border_color #89b4fa
inactive_border_color #6c7086
visual_bell_duration 0.1
visual_bell_color #f38ba8
enable_audio_bell no

# ===== Окно =====
remember_window_size yes
initial_window_width 1200
initial_window_height 700
window_padding_width 15 20
confirm_os_window_close 0
hide_window_decorations titlebar-only
window_margin_width 8

# ===== Прокрутка =====
scrollback_lines 20000
wheel_scroll_multiplier 8.0
touch_scroll_multiplier 3.0

# ===== Производительность =====
sync_to_monitor yes
repaint_delay 8
input_delay 2
linux_display_server auto
wayland_titlebar_color system

# ===== Unicode символы =====
symbol_map U+E0A0-U+E0A2,U+E0B0-U+E0B3 PowerlineSymbols
symbol_map U+E5FA-U+E62B,U+E700-U+E7C5,U+F000-U+F2E0,U+E200-U+E2A9,U+F500-U+FD46,U+E300-U+E3EB,U+F400-U+F4A8,U+2665,U+26A1,U+F27C,U+E0A3,U+E0B4-U+E0B8,U+23CF,U+E0C0-U+E0C2,U+E0C4-U+E0C8,U+E0CA-U+E0CC,U+E0CE-U+E0D2,U+E0D4 Symbols Nerd Font
